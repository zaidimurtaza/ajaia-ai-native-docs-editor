# App tables live in this Postgres schema (must match migrations; default ajaia).
# POSTGRES_SCHEMA=ajaia

# Supabase (Project Settings → Database): use Session pooler or Direct connection host/port.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Often required for Supabase:
# PGSSLMODE=require

# Comma-separated browser origins allowed to call the API (add your deployed UI URL).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app
