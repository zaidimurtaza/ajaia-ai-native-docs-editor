# App tables live in this Postgres schema (must match migrations; default ajaia).
# POSTGRES_SCHEMA=ajaia

# Supabase: Project Settings → Database → Connection string (URI).
# Pooler host looks like: aws-0-....pooler.supabase.com
# CRITICAL for pooler: POSTGRES_USER must be postgres.<project-ref> (not plain "postgres").
#   project-ref is the short id in the dashboard URL: supabase.com/dashboard/project/<project-ref>
# Wrong user → FATAL: Tenant or user not found
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres.your-project-ref-here
POSTGRES_PASSWORD=

# Often required for Supabase:
# PGSSLMODE=require

# Comma-separated browser origins allowed to call the API (add your deployed UI URL).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app

# Optional: APScheduler pings this URL every 2 minutes (requests GET) so free-tier hosts stay warm.
# On Render you can omit this if RENDER_EXTERNAL_URL is set — the app will use .../api/health.
# KEEPALIVE_HEALTH_URL=https://your-api.onrender.com/api/health
